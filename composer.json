{
    "name": "phalanx-php/styx",
    "description": "Reactive stream primitives for Phalanx",
    "license": "MIT",
    "type": "library",
    "keywords": ["reactive", "stream", "channel", "emitter", "backpressure", "async", "openswoole"],
    "authors": [
        {
            "name": "Jonathan Havens",
            "email": "mail@phalanx-php.com"
        }
    ],
    "homepage": "https://github.com/phalanx-php/phalanx-styx",
    "require": {
        "php": "^8.4",
        "ext-openswoole": "^26.0",
        "phalanx-php/aegis": "^0.6"
    },
    "autoload": {
        "psr-4": {
            "Phalanx\\Styx\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Phalanx\\Styx\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.2.x-dev"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
